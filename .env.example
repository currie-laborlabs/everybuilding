# ===========================
# Browserbase Configuration
# ===========================
# Get these from https://www.browserbase.com/settings
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# ===========================
# Reonomy Credentials
# ===========================
REONOMY_EMAIL=your_reonomy_email@example.com
REONOMY_PASSWORD=your_reonomy_password_here

# ===========================
# Stagehand LLM Configuration
# ===========================
# The model Stagehand uses for act/extract/observe.
# Options: gpt-4o, gpt-4o-mini, claude-3-5-sonnet-latest
STAGEHAND_MODEL=gpt-4o

# API key for the LLM provider (OpenAI key if using gpt-4o, Anthropic key if using Claude)
STAGEHAND_MODEL_API_KEY=your_openai_or_anthropic_api_key_here

# ===========================
# Scrape Run Configuration
# ===========================
# 5-digit ZIP code to search in Reonomy
REONOMY_ZIP_CODE=28202

# Maximum number of results pages to scrape (start with 1)
MAX_PAGES=1

# Maximum number of properties to process after extraction.
# Use 1 for the cheapest end-to-end smoke test.
# Set to 0 or leave unset for no property cap.
MAX_RESULTS=0

# Milliseconds to wait for page loads (increase if Reonomy is slow)
PAGE_LOAD_TIMEOUT=15000

# Milliseconds between actions (human-like delay)
ACTION_DELAY=2000

# ===========================
# Google Sheets Output
# ===========================
# Local file path to your Google service account JSON key
GOOGLE_SHEETS_CREDENTIALS_PATH=C:\\path\\to\\service-account.json

# Spreadsheet ID from your Google Sheet URL
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here

# Target tab name (created automatically if it does not exist)
GOOGLE_SHEETS_TAB_NAME=Leads

# Write header row when the tab is empty (true/false)
GOOGLE_SHEETS_HEADER_ROW=true

# ===========================
# Reliability / Orchestration
# ===========================
# Retry controls for stage executor wrappers
STAGE_MAX_ATTEMPTS=3
STAGE_RETRY_BASE_DELAY_MS=1000
STAGE_RETRY_MAX_DELAY_MS=8000

# Persist run-state checkpoints to disk
RUN_STATE_ENABLED=true
RUN_STATE_DIR=./tmp

# Global circuit breaker defaults
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=300000

# Provider rate limit defaults (per second)
ATTOM_RATE_LIMIT_PER_SECOND=1
APOLLO_RATE_LIMIT_PER_SECOND=3
HUNTER_RATE_LIMIT_PER_SECOND=2
ZEROBOUNCE_RATE_LIMIT_PER_SECOND=3

# ===========================
# Tier 2 — Email Outreach
# ===========================

# Anthropic API key — get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use. claude-haiku-4-5 is the recommended cost/quality balance.
# Full list: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-haiku-4-5

# Service account JSON for Tier 2 Google Sheet.
# Can reuse the same key as Tier 1 (GOOGLE_SHEETS_CREDENTIALS_PATH) if it has Sheets access.
# Source: Google Cloud Console → IAM → Service Accounts → Keys → Add Key (JSON)
TIER2_CREDENTIALS_PATH=C:\\path\\to\\service-account.json

# Google Sheets spreadsheet ID for this client's outreach sheet.
# Found in the sheet URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# Can reuse GOOGLE_SHEETS_SPREADSHEET_ID from Tier 1 if it's the same sheet.
TIER2_SPREADSHEET_ID=your_tier2_spreadsheet_id_here

# Sheet tab name where Tier 2 contacts live (same tab that Tier 1 writes to).
TIER2_SHEET_TAB=Leads

# ── JSON config files (in scraper/data/) ──────────────────────────────────────

# CTA_Playbook.json — The 10 email strategies with instructions, rules, examples.
# Created once by Jemuel from the CTA Playbook PDF spec. Same file across all clients.
# Template at: scraper/data/CTA_Playbook.json (edit to match your final playbook).
TIER2_CTA_PLAYBOOK_PATH=./data/CTA_Playbook.json

# Client_Voice_Profile.json — One file per client.
# Mary fills Client_Voice_Profile.docx from the 1-hour service audit call + web scrape.
# Jemuel converts the .docx to JSON using this schema.
# Sample at: scraper/data/Client_Voice_Profile.json (replace with real client data at onboarding).
TIER2_VOICE_PROFILE_PATH=./data/Client_Voice_Profile.json

# Campaign_Config.json — One file per client.
# Fill in after the Instantly campaign is created and sending domains are set up.
# instantly_campaign_id: found in Instantly dashboard → Campaigns → [Campaign] → Settings.
# sending_domain: the outreach domain registered for this client (e.g. outreach.clientdomain.com).
# Sample at: scraper/data/Campaign_Config.json.
TIER2_CAMPAIGN_CONFIG_PATH=./data/Campaign_Config.json

# Reprocessing mode: partial | full | failed_only
REPROCESS_MODE=partial

# Stage concurrency controls
ENRICHMENT_CONCURRENCY=4
VERIFICATION_CONCURRENCY=5

# Local Tier 1 runtime store (no app DB)
SQLITE_PATH=./tmp/tier1-runtime.db
CHECKPOINT_FILE=./tmp/tier1-checkpoint.json

# ===========================
# Tier 1 Provider APIs
# ===========================
# ATTOM property enrichment
ATTOM_API_KEY=
ATTOM_BASE_URL=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# Apollo contact enrichment
APOLLO_API_KEY=
APOLLO_BASE_URL=https://api.apollo.io/api/v1

# Hunter contact enrichment
HUNTER_API_KEY=
HUNTER_BASE_URL=https://api.hunter.io/v2

# ZeroBounce email verification
ZEROBOUNCE_API_KEY=
ZEROBOUNCE_BASE_URL=https://api.zerobounce.net/v2
